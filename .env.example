# ============================================================
# GoalGPT Mobile App - Environment Variables
# Copy this file to .env and fill in your actual values
# ============================================================
# IMPORTANT: All Expo vars MUST start with EXPO_PUBLIC_ prefix
# ============================================================

# ============================================================
# BACKEND API
# ============================================================
EXPO_PUBLIC_API_URL=https://partnergoalgpt.com/api
EXPO_PUBLIC_WS_URL=wss://partnergoalgpt.com/ws

# ============================================================
# ENVIRONMENT
# ============================================================
EXPO_PUBLIC_ENVIRONMENT=production   # development | staging | production

# ============================================================
# FEATURE FLAGS
# ============================================================
EXPO_PUBLIC_ENABLE_ANALYTICS=true
EXPO_PUBLIC_ENABLE_CRASH_REPORTING=true
EXPO_PUBLIC_ENABLE_GAMIFICATION=true

# ============================================================
# NOTE: The following are configured elsewhere
# ============================================================
#
# Firebase Config:
#   - iOS: GoogleService-Info.plist
#   - Android: google-services.json
#   - Project: santibet-715ef (intentional, existing users)
#
# AdMob Config:
#   - app.json → expo.plugins.react-native-google-mobile-ads
#   - Test IDs in development, real IDs in production build
#
# RevenueCat, Branch.io, Sentry:
#   - Configure in EAS secrets (eas.json submit section)
#   - Or add EXPO_PUBLIC_* vars as needed
#
# Google/Apple OAuth:
#   - app.json → expo.ios/android config
#   - EAS credentials management
#
# ============================================================
